{
  "id": "core.drop_shadow",
  "name": "Drop shadow",
  "category": "style",
  "params": [
    { "key": "offset_x", "label": "Offset X", "type": "float", "default": 14.0, "min": -150.0, "max": 150.0 },
    { "key": "offset_y", "label": "Offset Y", "type": "float", "default": 14.0, "min": -150.0, "max": 150.0 },
    { "key": "blur", "label": "Softness", "type": "float", "default": 10.0, "min": 0.0, "max": 80.0 },
    { "key": "opacity", "label": "Opacity", "type": "float", "default": 0.7, "min": 0.0, "max": 1.0 },
    { "key": "margin", "label": "Room", "type": "float", "default": 70.0, "min": 0.0, "max": 300.0 }
  ],
  "ffmpeg": "format=rgba,split[sh{u}a][sh{u}b];[sh{u}b]colorchannelmixer=rr=0:gg=0:bb=0:aa={opacity},gblur=sigma={blur},pad=iw+{margin}*2:ih+{margin}*2:max(0\\,{margin}+{offset_x}):max(0\\,{margin}+{offset_y}):color=black@0[sh{u}s];[sh{u}s][sh{u}a]overlay=x={margin}:y={margin}:format=auto",
  "notes": "Soft dark shadow behind the clip, offset by (offset_x, offset_y). Fast (no per-pixel geq). `margin` is the transparent room the shadow needs — keep it >= |offset| + 3*blur. Best on a PiP/overlay clip; on one with real transparency (PNG, keyed) it follows the shape."
}
